{
  "strategy": "simple_with_indicator",
  "imputer_fit_scope": "cv_inner_train_only",
  "add_missing_indicators": true,
  "complete_case_analysis": false,
  "forbid_test_usage": true,
  "test_used_for_fit": false,
  "valid_used_for_fit": false,
  "use_target_in_imputation": false,
  "max_feature_missing_ratio": 0.6,
  "min_non_missing_per_feature": 100,
  "indicator_required_above_ratio": 0.1,
  "missingness_drift_tolerance": 0.2,
  "large_data_row_threshold": 1000000,
  "large_data_col_threshold": 300,
  "mice_max_rows": 200000,
  "mice_max_cols": 200,
  "large_data_restricted_methods": [
    "mice",
    "missforest",
    "knn"
  ],
  "allowed_high_missing_features": [],
  "notes": "For large-scale medical tabular data, prefer train-fitted simple imputation + missing indicators unless justified otherwise."
}
