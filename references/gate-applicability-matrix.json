      },
      {
        "gate": "multiclass_fairness_gate",
        "replaces": "fairness_equity_gate (for multiclass)",
        "description": "Per-class equalized odds; macro fairness gap"
      },
      {
        "gate": "multiclass_threshold_gate",
        "new": true,
        "description": "Per-class threshold feasibility; OvR decision curves"
      },
      {
        "gate": "ordinal_consistency_gate",
        "new": true,
        "description": "Monotonicity for ordinal class labels; adjacent-class transition sanity"
