{
  "contract_version": "gate_applicability_matrix.v1",
  "description": "Defines which MLGG gates apply to which prediction types. In MLGG v1.0, all 31 gates apply to binary classification only. This matrix serves as the authoritative source for conditional gate execution in future versions.",
  "version": "1.0.0",
  "last_updated": "2026-03-15",

  "prediction_types": ["binary", "multiclass", "regression", "survival"],

  "legend": {
    "FULL": "Gate applies without modification",
    "ADAPTED": "Gate applies with prediction-type-specific logic branches (planned)",
    "REPLACED": "Gate is replaced by a type-specific equivalent gate (planned)",
    "NEW": "New gate required, no current equivalent (planned)",
    "NA": "Gate not applicable to this prediction type",
    "CONDITIONAL": "Gate applies only under specific conditions"
  },

  "core_gates": {
