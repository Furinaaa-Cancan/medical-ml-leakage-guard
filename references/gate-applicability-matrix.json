      "survival": "ADAPTED",
      "adaptation_notes": {
        "multiclass": "Add num_classes and class_labels validation",
        "regression": "Add outcome_unit field; remove label_col binary checks",
        "survival": "Add time_col, event_col, prediction_horizons validation"
      }
    },
