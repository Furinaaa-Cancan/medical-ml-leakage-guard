{
  "contract_version": "mlgg_compliance_certificate_schema.v1",
  "description": "JSON Schema (draft-07 compatible) for MLGG Compliance Certificates. A compliance certificate is a machine-readable, HMAC-signed artifact that attests to a prediction pipeline's conformance level. It can be submitted alongside a manuscript for independent verification by journal reviewers.",
  "schema_version": "1.0.0",
  "last_updated": "2026-03-15",

  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mlgg-standard.org/schemas/v1/compliance-certificate",
  "title": "MLGG Compliance Certificate",
  "type": "object",

  "certificate_fields_description": {
    "certificate_id": "Unique identifier for this certificate (UUID v4)",
    "mlgg_standard_version": "MLGG standard version used (e.g., '1.0.0')",
    "conformance_level": "Achieved conformance level: L1-Leakage-Audited, L2-Statistically-Valid, L3-Publication-Grade",
    "study_id": "Study identifier from request.json",
    "run_id": "Run identifier from request.json",
    "issued_at": "ISO 8601 UTC timestamp of certificate generation",
    "expires_at": "ISO 8601 UTC timestamp after which evidence should be re-verified (typically 2 years)",
    "gates_summary": "Summary of gate outcomes",
    "score_10dim": "Overall 10-dimension score (0–100)",
    "tripod_ai_coverage": "TRIPOD+AI item coverage (e.g., '23/27')",
    "probast_overall_rob": "PROBAST+AI overall risk of bias: low / unclear / high",
    "evidence_manifest": "SHA-256 hashes of all gate report files",
    "signature": "HMAC-SHA256 of the canonical certificate body"
  },

  "example_certificate": {
